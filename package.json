{
  "name": "oss-repo-check",
  "version": "1.0.0",
  "description": "OSS health scanning home for AINative-Studio repositories — powered by quaid-scanner",
  "type": "module",
  "private": true,
  "scripts": {
    "scan": "quaid-scanner . --quiet --format markdown",
    "scan:quick": "quaid-scanner . --depth quick",
    "scan:json": "quaid-scanner . --quiet --format json"
  },
  "dependencies": {
    "quaid-scanner": "^0.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AINative-Studio/oss-repo-check"
  },
  "license": "Apache-2.0"
}
